# ============================================================
# Variáveis de ambiente — copie para .env e preencha
# ============================================================

# Banco de dados Railway MySQL (gerado automaticamente pelo Railway)
DATABASE_URL=mysql://usuario:senha@host:3306/railway

# JWT — gere um segredo forte:
# rode no terminal: openssl rand -base64 32
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_AQUI

# Porta do servidor (Railway define automaticamente)
PORT=3000

# Ambiente
NODE_ENV=production
